# IMPORTANT: This is a template file showing example values
# Create actual .env files in each service directory with real values
# NEVER commit .env files to Git - they contain sensitive information
# Add .env to .gitignore

# ========================================
# USER SERVICE (.env)
# ========================================
PORT=3000
NODE_ENV=production

# MongoDB Connection (use Atlas or CosmosDB)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://smarteat_user:password123@cluster0.xxxxx.mongodb.net/user_db?retryWrites=true&w=majority

# Security
JWT_SECRET=your_very_secure_random_string_at_least_32_characters_long
JWT_EXPIRATION=7d
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=info

# ========================================
# RESTAURANT SERVICE (.env)
# ========================================
PORT=3000
NODE_ENV=production

MONGO_URI=mongodb+srv://smarteat_user:password123@cluster0.xxxxx.mongodb.net/restaurant_db?retryWrites=true&w=majority

JWT_SECRET=your_very_secure_random_string_at_least_32_characters_long
JWT_EXPIRATION=7d

# Inter-service communication
USER_SERVICE_URL=http://user-service.internal:3000

LOG_LEVEL=info

# ========================================
# ORDER SERVICE (.env)
# ========================================
PORT=3000
NODE_ENV=production

MONGO_URI=mongodb+srv://smarteat_user:password123@cluster0.xxxxx.mongodb.net/order_db?retryWrites=true&w=majority

JWT_SECRET=your_very_secure_random_string_at_least_32_characters_long
JWT_EXPIRATION=7d

# Inter-service communication
NOTIFICATION_SERVICE_URL=http://notification-service.internal:3000/api/notifications
RESTAURANT_SERVICE_URL=http://restaurant-service.internal:3000

LOG_LEVEL=info

# ========================================
# NOTIFICATION SERVICE (.env)
# ========================================
PORT=3000
NODE_ENV=production

MONGO_URI=mongodb+srv://smarteat_user:password123@cluster0.xxxxx.mongodb.net/notification_db?retryWrites=true&w=majority

JWT_SECRET=your_very_secure_random_string_at_least_32_characters_long
JWT_EXPIRATION=7d

# Email notifications (optional, if implementing email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_EMAIL=noreply@smarteat.com

LOG_LEVEL=info

# ========================================
# FRONTEND (.env)
# ========================================
VITE_API_BASE_URL=https://user-service.azurecontainerapps.io
VITE_USER_SERVICE_URL=https://user-service.azurecontainerapps.io/api
VITE_RESTAURANT_SERVICE_URL=https://restaurant-service.azurecontainerapps.io/api
VITE_ORDER_SERVICE_URL=https://order-service.azurecontainerapps.io/api
VITE_NOTIFICATION_SERVICE_URL=https://notification-service.azurecontainerapps.io/api

NODE_ENV=production

# ========================================
# INSTRUCTIONS FOR SETUP
# ========================================

# Step 1: Copy this file and create actual .env files
# cp .env.example .env

# Step 2: Edit each .env file with real values:
# - MongoDB connection strings from MongoDB Atlas
# - Generate secure JWT secrets:
#   Windows PowerShell: [Convert]::ToBase64String((Get-Random -Count 32 | ForEach-Object {[byte]$_}))
#   Linux/Mac: openssl rand -base64 32

# Step 3: Never commit .env files
# Ensure .gitignore contains:
# .env
# .env.local
# .env.*.local

# Step 4: For Azure deployment, use Key Vault instead:
# az keyvault secret set --vault-name smarteat-kv --name jwt-secret --value "your-secret"

# Step 5: Docker secrets example:
# echo "your_secret_value" | docker secret create jwt_secret -

# For Azure Container Apps:
# Pass secrets as environment variables during deployment:
# az containerapp create \
#   --name user-service \
#   --env-vars MONGO_URI='${{ secrets.MONGO_URI }}' JWT_SECRET='${{ secrets.JWT_SECRET }}'
